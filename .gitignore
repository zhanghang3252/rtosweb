.venv/

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === 环境配置 ===
.env
.env.local
.env.*.local

# === 日志 ===
*.log
logs/

# === 临时文件 ===
*.tmp
*.bak
*.cache

# === 不提交个人配置 ===
